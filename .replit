modules = ["nodejs-24", "python-base-3.13", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ZainJo Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ZainJo Frontend"

[[workflows.workflow]]
name = "ZainJo Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd zainjo-logstream/backend && CONFIG_PATH=../config.yaml uvicorn app.main:app --host 0.0.0.0 --port 8080 --loop uvloop"

[[workflows.workflow]]
name = "ZainJo Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd zainjo-logstream/frontend && PORT=${PORT:-3000} npm run dev"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "libyaml", "postgresql", "rustc"]
