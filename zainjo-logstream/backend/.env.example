# ZainJo LogStream — environment variable overrides
# Copy to .env if you prefer env vars over config.yaml.
# All variables are prefixed with LOGSTREAM_

LOGSTREAM_DATABASE_URL=postgresql+asyncpg://logstream:changeme@localhost:5432/logstream
LOGSTREAM_SECRET_KEY=change-this-to-a-random-64-char-string-in-production
CONFIG_PATH=/etc/zainjo-logstream/config.yaml
